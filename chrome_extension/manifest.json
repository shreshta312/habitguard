{
  "manifest_version": 3,
  "name": "HabitGuard",
  "version": "1.0.0",
  "description": "Personalized digital wellbeing intervention assistant.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],
  "action": {
    "default_title": "HabitGuard",
    "default_popup": "popup.html"
  }
}